# App URL (production / PayU callbacks)
NEXT_PUBLIC_APP_URL=https://twoja-domena.pl
# APP_URL=https://twoja-domena.pl

# Session & order storage: file (default) | redis
# SESSION_STORE=redis
# ORDER_STORE=redis

# Upstash Redis (rate limits, sessions, orders, idempotency)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Payments: demo (default) | live
PAYMENT_MODE=demo
# PAYMENT_PROVIDER=payu

# PayU (live mode)
# PAYU_ENV=sandbox
# PAYU_POS_ID=
# PAYU_CLIENT_ID=
# PAYU_CLIENT_SECRET=
# PAYU_MD5_KEY=

# Generic payment webhook (non-PayU)
# PAYMENT_WEBHOOK_SECRET=

# Email (Resend) — order confirmation & contact form
# RESEND_API_KEY=
# EMAIL_FROM=Mobillab+ <noreply@twoja-domena.pl>
# CONTACT_INBOX_EMAIL=kontakt@twoja-domena.pl

# NIP lookup (optional)
# GUS_REGON_API_KEY=
# CEIDG_API_TOKEN=
